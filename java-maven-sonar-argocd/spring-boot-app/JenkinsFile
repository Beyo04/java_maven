pipeline {
  agent {
    docker {
      image 'jibin321/maven-docker-agent:v2'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  environment {
    SONAR_URL = "http://43.204.107.210:9000"
    DOCKER_IMAGE = "beyons7/ultimate-cicd:${BUILD_NUMBER}"
    GIT_REPO_NAME = "java_maven"
    GIT_USER_NAME = "Beyo04"
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build and Test') {
      steps {
        sh '''
          cd java-maven-sonar-argocd/spring-boot-app
          mvn clean package
        '''
      }
    }

    stage('Static Code Analysis (SonarQube)') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          sh '''
            cd java-maven-sonar-argocd/spring-boot-app
            mvn sonar:sonar \
              -Dsonar.login=$SONAR_AUTH_TOKEN \
              -Dsonar.host.url=$SONAR_URL
          '''
        }
      }
    }

    stage('Build and Push Docker Image') {
      steps {
        script {
          sh '''
            cd java-maven-sonar-argocd/spring-boot-app
            docker build -t $DOCKER_IMAGE .
          '''

          def dockerImage = docker.image("${DOCKER_IMAGE}")

          docker.withRegistry('https://index.docker.io/v1/', 'docker_cred') {
            dockerImage.push()
          }
        }
      }
    }

    stage('Update Deployment File (ArgoCD)') {
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            git config --global --add safe.directory $WORKSPACE
            git config user.email "beyoncepaul6@gmail.com"
            git config user.name "Beyo04"

            sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" \
            java-maven-sonar-argocd/spring-boot-app-manifests/deployment.yml

            git add java-maven-sonar-argocd/spring-boot-app-manifests/deployment.yml

            git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes to commit"

            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
          '''
        }
      }
    }
  }
}
